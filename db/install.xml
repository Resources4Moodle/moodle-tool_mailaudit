<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="admin/tool/mailaudit/db" VERSION="2026070100" COMMENT="XMLDB file for Moodle mail audit tool"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="../../../../lib/xmldb/xmldb.xsd"
>
  <TABLES>
    <TABLE NAME="tool_mailaudit_mail" COMMENT="Stores audited outbound Moodle email messages">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="status" TYPE="char" LENGTH="16" NOTNULL="true" SEQUENCE="false" DEFAULT="sent"/>
        <FIELD NAME="kind" TYPE="char" LENGTH="40" NOTNULL="true" SEQUENCE="false" DEFAULT="other"/>
        <FIELD NAME="courseid" TYPE="int" LENGTH="10" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="component" TYPE="char" LENGTH="100" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="messagename" TYPE="char" LENGTH="100" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="originfile" TYPE="char" LENGTH="255" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="originline" TYPE="int" LENGTH="10" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="messageid" TYPE="char" LENGTH="255" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="moodlemessageid" TYPE="int" LENGTH="10" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="moodlemessagetable" TYPE="char" LENGTH="20" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="subject" TYPE="text" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="bodytext" TYPE="text" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="bodyhtml" TYPE="text" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="fromuserid" TYPE="int" LENGTH="10" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="fromemail" TYPE="char" LENGTH="255" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="fromname" TYPE="char" LENGTH="255" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="fromusername" TYPE="char" LENGTH="100" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="fromfirstname" TYPE="char" LENGTH="100" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="fromlastname" TYPE="char" LENGTH="100" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="touserid" TYPE="int" LENGTH="10" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="toemail" TYPE="char" LENGTH="255" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="toname" TYPE="char" LENGTH="255" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="tousername" TYPE="char" LENGTH="100" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="tofirstname" TYPE="char" LENGTH="100" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="tolastname" TYPE="char" LENGTH="100" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="coursefullname" TYPE="char" LENGTH="255" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="courseshortname" TYPE="char" LENGTH="255" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="replyto" TYPE="char" LENGTH="255" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="attachmentcount" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" DEFAULT="0"/>
        <FIELD NAME="attachmentnames" TYPE="text" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="bodybytes" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" DEFAULT="0"/>
        <FIELD NAME="classificationnote" TYPE="text" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="requestuserid" TYPE="int" LENGTH="10" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="requestip" TYPE="char" LENGTH="45" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="useragent" TYPE="text" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="stackjson" TYPE="text" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="metadata" TYPE="text" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="deleted" TYPE="int" LENGTH="1" NOTNULL="true" SEQUENCE="false" DEFAULT="0"/>
        <FIELD NAME="timedeleted" TYPE="int" LENGTH="10" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="deletedby" TYPE="int" LENGTH="10" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="deletebatch" TYPE="char" LENGTH="40" NOTNULL="false" SEQUENCE="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="timecreated" UNIQUE="false" FIELDS="timecreated"/>
        <INDEX NAME="moodlemsg" UNIQUE="false" FIELDS="moodlemessagetable, moodlemessageid"/>
        <INDEX NAME="messageid" UNIQUE="false" FIELDS="messageid"/>
        <INDEX NAME="deleted_timecreated" UNIQUE="false" FIELDS="deleted, timecreated"/>
        <INDEX NAME="kind_timecreated" UNIQUE="false" FIELDS="kind, timecreated"/>
        <INDEX NAME="status_timecreated" UNIQUE="false" FIELDS="status, timecreated"/>
        <INDEX NAME="course_timecreated" UNIQUE="false" FIELDS="courseid, timecreated"/>
        <INDEX NAME="fromuser_timecreated" UNIQUE="false" FIELDS="fromuserid, timecreated"/>
        <INDEX NAME="touser_timecreated" UNIQUE="false" FIELDS="touserid, timecreated"/>
        <INDEX NAME="fromlastname" UNIQUE="false" FIELDS="fromlastname"/>
        <INDEX NAME="tolastname" UNIQUE="false" FIELDS="tolastname"/>
      </INDEXES>
    </TABLE>
    <TABLE NAME="tool_mailaudit_access" COMMENT="Audits access to the mail audit tool itself">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="action" TYPE="char" LENGTH="40" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="mailid" TYPE="int" LENGTH="10" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="criteria" TYPE="text" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="requestip" TYPE="char" LENGTH="45" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="useragent" TYPE="text" NOTNULL="false" SEQUENCE="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="timecreated" UNIQUE="false" FIELDS="timecreated"/>
        <INDEX NAME="userid" UNIQUE="false" FIELDS="userid"/>
        <INDEX NAME="action" UNIQUE="false" FIELDS="action"/>
        <INDEX NAME="mailid" UNIQUE="false" FIELDS="mailid"/>
      </INDEXES>
    </TABLE>
  </TABLES>
</XMLDB>
